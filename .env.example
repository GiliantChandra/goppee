# Environment Variables Template
# Copy this file to .env and fill in your own values
# NEVER commit the actual .env file to Git

# ─── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
DEMO_MODE=true

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://novapay:CHANGE_THIS_PASSWORD@localhost:5432/novapay_db"
DB_PASSWORD=CHANGE_THIS_PASSWORD

# ─── JWT Secrets ──────────────────────────────────────────────────────────────
# Generate strong secrets with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=CHANGE_THIS_TO_A_LONG_RANDOM_STRING_AT_LEAST_64_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_LONG_RANDOM_STRING_DIFFERENT_FROM_ABOVE
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ─── Encryption ───────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=CHANGE_THIS_32_BYTE_HEX_KEY_FOR_AES256

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGIN=http://localhost:5173

# ─── Rate Limiting ────────────────────────────────────────────────────────────
RATE_LIMIT_WINDOW_MS=60000
LOGIN_RATE_LIMIT_MAX=5
TRANSFER_RATE_LIMIT_MAX=10
TOPUP_RATE_LIMIT_MAX=5

# ─── OTP ──────────────────────────────────────────────────────────────────────
OTP_EXPIRES_MINUTES=5
OTP_MAX_ATTEMPTS=3

# ─── Account Lockout ──────────────────────────────────────────────────────────
MAX_FAILED_LOGIN_ATTEMPTS=5

# ─── Demo Seed User ───────────────────────────────────────────────────────────
SEED_USER_EMAIL=arjuna@novapay.id
SEED_USER_PASSWORD=Password1!
SEED_USER_PIN=1234
